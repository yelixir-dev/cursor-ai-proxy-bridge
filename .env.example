# Cursor AI Bridge runtime configuration
# Copy to .env and edit before exposing /v1 endpoints.

CURSOR_BRIDGE_HOST=127.0.0.1
CURSOR_BRIDGE_PORT=9994

# Required for /v1/* routes. Use a long random value in real deployments.
CURSOR_BRIDGE_API_KEY=replace-with-a-long-random-client-key

# Use mock for local dashboard/API smoke tests; use cursor-cli for real Cursor backend.
CURSOR_BRIDGE_BACKEND=mock
CURSOR_BRIDGE_DEFAULT_MODEL=cursor-fast

# Safe default: do not mount a real workspace.
CURSOR_BRIDGE_WORKSPACE_MODE=chat-only
# CURSOR_BRIDGE_WORKSPACE_MODE=real-workspace
# CURSOR_BRIDGE_REAL_WORKSPACE=/absolute/path/to/project

# Cursor CLI backend settings.
CURSOR_BRIDGE_CURSOR_BIN=cursor
CURSOR_BRIDGE_CURSOR_TIMEOUT_MS=120000
